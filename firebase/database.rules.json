{
  "rules": {
    "userDevices": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "devices": {
      "$deviceId": {
        "live": {
          ".read": "auth != null || query.orderByChild == 'public'",
          ".write": false
        },
        "commands": {
          "latest": {
            ".read": false,
            ".write": "auth != null || (data == null && newData.child('cmd').val() == 'stop')"
          }
        },
        "history": {
          ".read": "auth != null",
          ".write": false
        },
        "owner_notes": {
          ".read": "auth != null",
          ".write": "auth != null"
        },
        "therapy_events": {
          ".read": "auth != null",
          ".write": false
        }
      }
    }
  }
}
